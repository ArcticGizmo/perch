<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Perch.Avalonia.ViewModels"
             x:Class="Perch.Avalonia.Views.OverlayView"
             x:DataType="vm:OverlayViewModel"
             Width="280">

    <!-- The live overlay body, split out of the window so it can be render-tested headlessly and
         reused as the Phase-4 overlay grows. The header is the drag handle; each row is clickable. -->
    <Border Background="#F50F0F14" BorderBrush="#2D2D3C" BorderThickness="1"
            CornerRadius="12" Padding="12">
        <StackPanel Spacing="8">
            <TextBlock Name="Header" Text="{Binding Header}"
                       Foreground="#E1E1EB" FontSize="14" FontWeight="SemiBold"
                       PointerPressed="OnHeaderPressed" />
            <ItemsControl ItemsSource="{Binding Sessions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SessionRowViewModel">
                        <Border Background="Transparent" Padding="4,5" CornerRadius="6"
                                Cursor="Hand" PointerPressed="OnRowPressed">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Ellipse Grid.Column="0" Width="9" Height="9"
                                         VerticalAlignment="Center" Margin="0,0,9,0"
                                         Fill="{Binding StatusBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                           Foreground="#E1E1EB" FontSize="13"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                                           Foreground="#8C8CA0" FontSize="11" Margin="8,0,0,0"
                                           TextTrimming="CharacterEllipsis" MaxWidth="120"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="drag the title to move · click a row to focus"
                       Foreground="#6E6E82" FontSize="10" />
        </StackPanel>
    </Border>
</UserControl>
